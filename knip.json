{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "e2e/global-setup.ts",
    "e2e/fixtures/auth.setup.ts"
  ],
  "project": [
    "src/**/*.ts",
    "e2e/**/*.ts",
    "tests/**/*.ts",
    "*.config.mjs",
    "*.mjs"
  ],
  "ignoreIssues": {
    "src/types/**/*.ts": [
      "types"
    ],
    "src/components/autosnooze-actions-controller.ts": [
      "exports"
    ],
    "e2e/helpers/**/*.ts": [
      "exports",
      "types"
    ],
    "tests/helpers/**/*.ts": [
      "exports",
      "types"
    ]
  },
  "ignoreBinaries": [
    "python3"
  ],
  "node": false,
  "treatConfigHintsAsErrors": true
}
