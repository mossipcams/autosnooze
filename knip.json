{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "src/index.ts",
    "e2e/global-setup.ts",
    "e2e/fixtures/auth.setup.ts"
  ],
  "project": [
    "src/**/*.ts",
    "e2e/**/*.ts",
    "tests/**/*.ts",
    "*.config.mjs",
    "*.mjs"
  ],
  "ignoreIssues": {
    "src/types/**/*.ts": [
      "types"
    ],
    "tests/helpers/**/*.ts": [
      "exports",
      "types"
    ]
  },
  "node": false,
  "treatConfigHintsAsErrors": true
}
