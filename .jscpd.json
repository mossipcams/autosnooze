{
  "absolute": true,
  "threshold": 0,
  "minLines": 10,
  "minTokens": 60,
  "mode": "strict",
  "gitignore": true,
  "reporters": [
    "console"
  ],
  "pattern": "**/*.ts",
  "ignore": [
    "**/*.d.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "src/index.ts",
    "src/styles/**",
    "src/localization/translations/**"
  ]
}
