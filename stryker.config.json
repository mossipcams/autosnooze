{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "mutate": ["src/**/*.ts", "!src/**/*.test.ts", "!src/**/*.spec.ts"],
  "reporters": ["clear-text", "progress", "html"],
  "concurrency": 4,
  "timeoutMS": 30000,
  "vitest": {
    "configFile": "vitest.config.mjs"
  }
}
