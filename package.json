{
  "name": "autosnooze",
  "version": "0.2.25",
  "description": "AutoSnooze - Temporarily pause Home Assistant automations",
  "main": "custom_components/autosnooze/www/autosnooze-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:smoke": "playwright test --config=e2e/playwright.config.ts --grep @smoke",
    "e2e:visual": "playwright test --config=e2e/playwright.config.ts --grep @visual",
    "e2e:visual:headed": "PLAYWRIGHT_HEADED_SNAPSHOTS=1 playwright test --config=e2e/playwright.config.ts --grep @visual",
    "e2e:critical": "playwright test --config=e2e/playwright.config.ts --grep @critical",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "smoke": "npm run smoke:backend",
    "smoke:backend": "python3 -m pytest -q tests/test_smoke.py",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs src",
    "lint:duplicates": "jscpd --config .jscpd.json src",
    "lint:unused": "knip --config knip.json --reporter compact",
    "lint:unused:prod": "knip --config knip.production.json --reporter compact --production",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "prepare": "node scripts/install-husky-if-local.mjs",
    "mutation:backend": "python3 scripts/run_backend_mutation.py",
    "test:mutation:notification-trigger": "stryker run stryker.notification-trigger.config.mjs"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "i18n"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stryker-mutator/api": "^9.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.0.0",
    "jscpd": "^4.2.4",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "rollup": "^4.62.0",
    "tdd-guard-vitest": "^0.2.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.16",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "underscore": "1.13.8",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "@anthropic-ai/claude-agent-sdk": {
      "@anthropic-ai/sdk": "0.91.1"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    }
  },
  "optionalDependencies": {
    "@oxc-parser/binding-darwin-arm64": "0.136.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.136.0",
    "@oxc-resolver/binding-darwin-arm64": "11.20.0",
    "@oxc-resolver/binding-linux-x64-gnu": "11.20.0",
    "@rollup/rollup-darwin-arm64": "4.62.0",
    "@rollup/rollup-linux-x64-gnu": "4.62.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ],
    "tests/**/*.{js,ts}": [
      "eslint --fix"
    ],
    "custom_components/**/*.py": [
      "bash -c 'command -v ruff &>/dev/null && ruff check --fix \"$@\" || echo \"ruff not installed, skipping\"' --",
      "bash -c 'command -v ruff &>/dev/null && ruff format \"$@\" || true' --"
    ],
    "tests/**/*.py": [
      "bash -c 'command -v ruff &>/dev/null && ruff check --fix \"$@\" || echo \"ruff not installed, skipping\"' --",
      "bash -c 'command -v ruff &>/dev/null && ruff format \"$@\" || true' --"
    ]
  }
}
